<!doctype html>
<html lang="ar" dir="rtl">
<head>
  {% hook 'head:start' %}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#f97316">
  <title>{% block title %}سدادي{% endblock %}</title>
  <link rel="icon" href="{{ 'images/favicon.svg' | asset }}">
  <link rel="stylesheet" href="{{ 'css/sadady-home.css' | asset }}">
  <link rel="stylesheet" href="{{ 'css/sadady-journey.css' | asset }}">
  <script type="module" src="{{ 'js/sadady/theme-api.js' | asset }}"></script>
  <script type="module" src="{{ 'js/sadady/auth.js' | asset }}"></script>
  <script type="module" src="{{ 'js/sadady/session-strip.js' | asset }}"></script>
  {% block styles %}{% endblock %}
  <script>
    window.SADADY_SALLA_CUSTOMER = {
      id: "{{ customer.id|default('')|e('js') }}",
      name: "{{ customer.name|default('')|e('js') }}",
      phone: "{{ customer.mobile|default(customer.phone)|default('')|e('js') }}",
      email: "{{ customer.email|default('')|e('js') }}",
      source: "salla"
    };
    window.SADADY_DEBUG_CUSTOMER =
      typeof window !== "undefined" &&
      new URLSearchParams(window.location.search).get("sadady_debug_customer") === "1";
    console.log("Sadady Salla customer id:", window.SADADY_SALLA_CUSTOMER.id || "");
    console.log("Sadady Salla customer phone:", window.SADADY_SALLA_CUSTOMER.phone || "");
  </script>
  {% block head %}{% endblock %}
  {% hook head %}
  {% hook 'head:end' %}
</head>
<body id="top">
  {% hook 'body:start' %}
  {% if customer is defined %}
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        if (!window.SADADY_DEBUG_CUSTOMER) return;
        var debugCard = document.createElement("div");
        debugCard.style.cssText = "position:fixed;bottom:12px;left:12px;background:#fff3cd;border:1px solid #f1c40f;padding:10px;z-index:9999;font:12px/1.6 sans-serif;direction:ltr;text-align:left";
        debugCard.innerHTML =
          "Salla Customer ID: {{ customer.id|default('N/A')|e('js') }}" +
          "<br>" +
          "Salla Customer Phone: {{ customer.phone|default(customer.mobile)|default('N/A')|e('js') }}";
        document.body.appendChild(debugCard);
      });
    </script>
  {% endif %}
  {% block content %}{% endblock %}
  {% block scripts %}{% endblock %}
  {% hook 'body:end' %}
</body>
</html>
