<!doctype html>
<html lang="ar" dir="rtl">
<head>
  {% hook 'head:start' %}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#f97316">
  <meta name="sadady-api-base" content="{{ theme.settings.get('api_base_url')|default('https://api.sadady.com') }}">
  <meta name="sadady-support-email" content="{{ theme.settings.get('support_email')|default('support@sadady.com') }}">
  <title>{% block title %}سدادي{% endblock %}</title>
  <link rel="icon" href="{{ 'images/favicon.svg' | asset }}">
  <link rel="stylesheet" href="{{ 'css/sadady-home.css' | asset }}">
  <link rel="stylesheet" href="{{ 'css/sadady-journey.css' | asset }}">
  <script type="module" src="{{ 'js/sadady/theme-api.js' | asset }}"></script>
  <script type="module" src="{{ 'js/sadady/auth.js' | asset }}"></script>
  {% block styles %}{% endblock %}
  {% block head %}{% endblock %}
  {% hook head %}
  {% hook 'head:end' %}
</head>
<body id="top" class="sadady-theme" {% hook 'body:classes' %}>
  {% hook 'body:start' %}
  {% block content %}{% endblock %}
  {% block scripts %}{% endblock %}
  {% hook 'body:end' %}
</body>
</html>
